---
import type { SentenceFrame } from '../content/schema';

interface Props {
  frame: SentenceFrame;
}
const { frame } = Astro.props;

const roleLabel: Record<string, string> = {
  pos1:       'Position 1',
  verb:       'Verb',
  mittelfeld: 'Mittelfeld',
  satzende:   'Satzende',
  'verb-end': 'Verb (Ende)',
};

const verbSlot = (slot: SentenceFrame['slots'][number]) =>
  slot.highlight || slot.role === 'verb' || slot.role === 'verb-end';
---
<div class="sf">
  <div class="sf__diagram">
    {frame.slots.map((slot) => (
      <div class={`sf__slot${verbSlot(slot) ? ' sf__slot--verb' : ''}`}>
        {slot.role && (
          <div class="sf__role eyebrow">{roleLabel[slot.role] ?? slot.role}</div>
        )}
        <div class="sf__text">{slot.text}</div>
      </div>
    ))}
  </div>

  {frame.showBracket && (
    <div class="sf__bracket" aria-hidden="true">
      <svg width="100%" height="18" viewBox="0 0 400 18" preserveAspectRatio="none">
        <line x1="0" y1="9" x2="400" y2="9"
          stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="4 3" />
        <polygon points="0,4 0,14 8,9" fill="var(--accent)" />
        <polygon points="400,4 400,14 392,9" fill="var(--accent)" />
      </svg>
      <span class="sf__bracket-label eyebrow">Verbklammer</span>
    </div>
  )}

  {frame.caption && (
    <p class="sf__caption">{frame.caption}</p>
  )}
</div>

<style>
  .sf {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 1.25rem 1.5rem 1rem;
    font-family: var(--font-mono);
  }

  .sf__diagram {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    align-items: flex-end;
  }

  .sf__slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .25rem;
  }

  .sf__role {
    font-size: 10px;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .sf__text {
    background: var(--slot);
    border-radius: var(--r-sm);
    padding: .4rem .75rem;
    font-size: .9375rem;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
  }

  .sf__slot--verb .sf__text {
    background: var(--accent-tint);
    color: var(--accent-deep);
    font-weight: 700;
  }

  .sf__bracket {
    margin-top: .5rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .sf__bracket svg {
    flex: 1;
  }

  .sf__bracket-label {
    white-space: nowrap;
    color: var(--accent-deep);
    font-size: 10px;
  }

  .sf__caption {
    margin: .75rem 0 0;
    font-family: var(--font-sans);
    font-size: .875rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
</style>
