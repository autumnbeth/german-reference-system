---
import type { VocabGroup } from '../content/schema';

interface Props {
  group: VocabGroup;
}
const { group } = Astro.props;

const articleMap: Record<string, string> = { der: 'der', die: 'die', das: 'das', pl: 'die' };
---
<div class="vg">
  <div class="eyebrow vg__label">{group.label}</div>
  <div class="vg__list">
    {group.items.map((item) => (
      <div class="vg__row">
        <span class={`vg__art art art--${item.gender}`}>{articleMap[item.gender]}</span>
        <span class="vg__word">{item.word}</span>
        <span class="vg__meaning gloss">{item.meaning}</span>
        {(item.plural || item.note) && (
          <span class="vg__meta">
            {item.plural && `Pl. ${item.plural}`}
            {item.plural && item.note && ' · '}
            {item.note}
          </span>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .vg {
    margin-bottom: 1.75rem;
  }

  .vg__label {
    margin-bottom: .625rem;
    padding-bottom: .375rem;
    border-bottom: 1px solid var(--border);
  }

  .vg__list {
    display: flex;
    flex-direction: column;
  }

  .vg__row {
    display: grid;
    grid-template-columns: 2.25rem 1fr 1fr auto;
    align-items: baseline;
    gap: 0 1rem;
    padding: .4rem 0;
    border-bottom: 1px solid var(--border-2);
    font-family: var(--font-sans);
  }

  .vg__row:last-child {
    border-bottom: none;
  }

  .vg__art {
    font-size: .8125rem;
    font-weight: 700;
    text-align: right;
    white-space: nowrap;
  }

  .vg__word {
    font-size: .9375rem;
    font-weight: 600;
    color: var(--ink);
  }

  .vg__meaning {
    font-size: .875rem;
  }

  .vg__meta {
    font-size: .75rem;
    color: var(--ink-soft);
    white-space: nowrap;
    text-align: right;
  }

  @media (max-width: 560px) {
    .vg__row {
      grid-template-columns: 2.25rem 1fr;
      row-gap: .1rem;
    }

    .vg__meaning {
      grid-column: 2;
    }

    .vg__meta {
      grid-column: 2;
      text-align: left;
    }
  }
</style>
