---
import SiteNav from '../components/SiteNav.astro';

// Self-hosted fonts (GDPR: no visitor data leaves the site)
import '@fontsource/newsreader/400.css';
import '@fontsource/newsreader/500.css';
import '@fontsource/newsreader/600.css';
import '@fontsource/newsreader/400-italic.css';
import '@fontsource/newsreader/500-italic.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '@fontsource/hanken-grotesk/700.css';
import '@fontsource/hanken-grotesk/800.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';

interface Props {
  title?: string;
}
const { title = 'Lingo Goblin · German Reference' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}/favicon.png`} />
  </head>
  <body>
    <SiteNav />
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
</style>
