---
import SiteNav from '../components/SiteNav.astro';

interface Props {
  title?: string;
}
const { title = 'Lingo Goblin · German Reference' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}/favicon.png`} />

    <!-- Google Fonts: Newsreader · Hanken Grotesk · JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <SiteNav />
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
</style>
