---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Lingo Goblin · German, devoured.">
  <div class="home">

    <header class="home__hero">
      <div class="home__hero-text">
        <div class="eyebrow home__eyebrow">A1 → C1 · situation-based</div>
        <h1 class="home__title">Swallow the dictionary.<br /><em class="home__title-accent">Keep the words.</em></h1>
        <p class="home__lede">Real German for real situations — with a goblin that eats grammar so it finally sticks.</p>
      </div>
      <img
        src={`${base}/images/brand/goblin-hero.png`}
        alt="Lingo Goblin devouring a German dictionary"
        class="home__goblin"
      />
    </header>

    <main class="home__entries">

      <a href={`${base}/foundation/`} class="entry-card">
        <div class="eyebrow entry-card__eyebrow">How German works</div>
        <h2 class="entry-card__title">Grammar Foundations</h2>
        <p class="entry-card__body">
          The architecture of German as one connected system — sentence structure,
          verbs and tenses, the gender-colored case system, and how clauses connect.
          See the map; dive in where you need it.
        </p>
        <span class="entry-card__cta">Explore the foundation →</span>
      </a>

      <a href={`${base}/situations/`} class="entry-card">
        <div class="eyebrow entry-card__eyebrow">Where German is used</div>
        <h2 class="entry-card__title">Real-Life Situations</h2>
        <p class="entry-card__body">
          Themed real-world pages — from the Apotheke to a doctor's visit — each
          with key vocabulary, dialogue, and writing, growing with you from A1 to C1.
        </p>
        <span class="entry-card__cta">Browse situations →</span>
      </a>

    </main>

  </div>
</BaseLayout>

<style>
  .home {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  /* ── Hero ── */
  .home__hero {
    padding: 4rem 0 3.5rem;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .home__hero-text { max-width: 600px; }

  .home__goblin {
    width: 220px;
    height: auto;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 720px) {
    .home__goblin { width: 150px; }
  }

  @media (max-width: 560px) {
    .home__goblin { display: none; }
  }

  .home__eyebrow { margin-bottom: .875rem; }

  .home__title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 1rem;
    line-height: 1.08;
    letter-spacing: -.015em;
  }

  .home__title-accent {
    color: var(--accent-deep);
  }

  .home__lede {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink-body);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Entry cards ── */
  .home__entries {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .home__entries { grid-template-columns: 1fr; }
  }

  .entry-card {
    display: flex;
    flex-direction: column;
    gap: .875rem;
    padding: 2rem 2rem 1.75rem;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    transition: box-shadow .2s, border-color .2s, transform .2s;
  }

  .entry-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-tint);
    transform: translateY(-2px);
  }

  .entry-card__eyebrow { color: var(--ink-faint); }

  .entry-card__title {
    font-family: var(--font-serif);
    font-size: 1.625rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    line-height: 1.2;
  }

  .entry-card__body {
    font-family: var(--font-serif);
    font-size: .9375rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .entry-card__cta {
    font-family: var(--font-sans);
    font-size: .875rem;
    font-weight: 600;
    color: var(--accent-deep);
    margin-top: .25rem;
  }
</style>
