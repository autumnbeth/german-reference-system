---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TenseMap from '../../components/TenseMap.astro';
import TenseLadder from '../../components/TenseLadder.astro';
import ModalStack from '../../components/ModalStack.astro';
import DeclensionTableComponent from '../../components/DeclensionTable.astro';
import VerbConjugationComponent from '../../components/VerbConjugation.astro';
import SentenceFrameComponent from '../../components/SentenceFrame.astro';
import ConnectorList from '../../components/ConnectorList.astro';
import FoundationSections from '../../components/FoundationSections.astro';
import ProgressionTable from '../../components/ProgressionTable.astro';
import Callout from '../../components/Callout.astro';
import { foundationTopics, getFoundationTopic, getFoundationByCategory, getTopicChildren } from '../../data/foundation';
import { situations } from '../../data/index';

export function getStaticPaths() {
  return foundationTopics.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const topic = getFoundationTopic(slug);
if (!topic) throw new Error(`No foundation topic for slug: ${slug}`);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const hasContent =
  (topic.sections?.length ?? 0) > 0 ||
  (topic.tenseLadder?.length ?? 0) > 0 ||
  (topic.tenseOverviews?.length ?? 0) > 0 ||
  (topic.verbConjugations?.length ?? 0) > 0 ||
  (topic.sentenceFrames?.length ?? 0) > 0 ||
  (topic.progression?.length ?? 0) > 0 ||
  (topic.modalStack?.length ?? 0) > 0 ||
  (topic.declensionTables?.length ?? 0) > 0;

const relatedSits = (topic.relatedSituations ?? [])
  .map((s) => situations.find((sit) => sit.slug === s))
  .filter(Boolean);

const navGroups = getFoundationByCategory();
const children = getTopicChildren(slug);
const parentTopic = topic.parent ? getFoundationTopic(topic.parent) : null;
const siblings = parentTopic ? getTopicChildren(parentTopic.slug) : [];
---
<BaseLayout title={`${topic.title} · Foundation · German Reference System`}>
  <div class="foundation-shell">

    <!-- ── Mobile nav toggle ── -->
    <button class="sidebar-toggle" id="foundation-sidebar-toggle" aria-expanded="false" aria-controls="foundation-sidebar">
      <span aria-hidden="true">☰</span>
      <span>Navigate</span>
    </button>

    <!-- ── Sidebar ── -->
    <nav class="sidebar" id="foundation-sidebar" aria-label="Foundation topics">
      <a href={`${base}/foundation/`} class="sidebar__home eyebrow">← Grammar Foundation</a>
      {Object.entries(navGroups).map(([category, topics]) => (
        <div class="sidebar__group">
          <a
            href={`${base}/foundation/#${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="sidebar__theme eyebrow"
          >{category}</a>
          <ul class="sidebar__list">
            {topics.map((t) => {
              const tChildren = getTopicChildren(t.slug);
              const isParentOfActive = tChildren.some((c) => c.slug === slug);
              return (
                <li>
                  <a
                    href={`${base}/foundation/${t.slug}/`}
                    class={`sidebar__link${(t.slug === slug || isParentOfActive) ? ' sidebar__link--active' : ''}`}
                  >{t.title}{tChildren.length > 0 ? ' ›' : ''}</a>
                  {tChildren.length > 0 && (
                    <ul class="sidebar__children">
                      {tChildren.map((c) => (
                        <li>
                          <a
                            href={`${base}/foundation/${c.slug}/`}
                            class={`sidebar__link sidebar__link--child${c.slug === slug ? ' sidebar__link--active' : ''}`}
                          >{c.title}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </nav>

    <!-- ── Main content ── -->
  <div class="spoke">

    {/* Breadcrumb for child pages */}
    {parentTopic && (
      <nav class="spoke__breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/foundation/${parentTopic.slug}/`} class="spoke__back">← {parentTopic.title}</a>
        <div class="spoke__sibling-strip">
          {siblings.map((s) => (
            <a
              href={`${base}/foundation/${s.slug}/`}
              class={`spoke__sibling-link${s.slug === slug ? ' spoke__sibling-link--active' : ''}`}
            >{s.title}</a>
          ))}
        </div>
      </nav>
    )}

    <header class="spoke__header">
      {topic.category && !parentTopic && (
        <div class="eyebrow spoke__category">{topic.category}</div>
      )}
      <h1 class="spoke__title">{topic.title}</h1>
      <p class="spoke__intro">{topic.intro}</p>
    </header>

    {!hasContent && (
      <div class="spoke__placeholder">
        <div class="placeholder-card">
          <div class="eyebrow placeholder-card__label">Content coming soon</div>
          <p class="placeholder-card__body">
            The {topic.title} page will include sentence-structure diagrams,
            a CEFR progression table, and worked examples drawn from real situations.
            Drop in the data and this page renders automatically.
          </p>
        </div>
      </div>
    )}

    {/* Verb conjugations — rendered first so auxiliaries anchor the page */}
    {topic.verbConjugations && topic.verbConjugations.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">The Three Auxiliaries — haben · sein · werden</h2>
        <div class="spoke__verbs">
          {topic.verbConjugations.map((v) => (
            <VerbConjugationComponent verb={v} />
          ))}
        </div>
      </section>
    )}

    {/* Named sections */}
    {topic.sections && topic.sections.length > 0 && (
      <FoundationSections sections={topic.sections} />
    )}

    {/* Accordion for parent topics — renders each child's content inline */}
    {children.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">The Tenses — Deep Dive</h2>
        <div class="tense-accordion">
          {children.map((c) => (
            <details class="tense-accordion__item">
              <summary class="tense-accordion__summary">
                <span class="tense-accordion__title">{c.title}</span>
                {(c.summary ?? c.teaser) && <span class="tense-accordion__teaser">{c.summary ?? c.teaser}</span>}
                <span class="tense-accordion__chevron" aria-hidden="true">›</span>
              </summary>
              <div class="tense-accordion__body">
                {c.sections && c.sections.length > 0 && (
                  <FoundationSections sections={c.sections} headingLevel="h3" />
                )}
                <a href={`${base}/foundation/${c.slug}/`} class="tense-accordion__full-link">
                  Open full page →
                </a>
              </div>
            </details>
          ))}
        </div>
      </section>
    )}

    {/* Tense ladder (tense-stack page) — visual reference below the accordion */}
    {topic.tenseLadder && topic.tenseLadder.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">The Tense Ladder</h2>
        <TenseLadder rows={topic.tenseLadder} habenSein={topic.habenSein} base={base} />
      </section>
    )}

    {/* Top-level declension tables (case system) */}
    {topic.declensionTables && topic.declensionTables.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Article Declension</h2>
        <DeclensionTableComponent tables={topic.declensionTables} />
      </section>
    )}

    {/* Modal stacking table */}
    {topic.modalStack && topic.modalStack.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Modal Stacking — All Constructions</h2>
        <ModalStack rows={topic.modalStack} />
      </section>
    )}

    {/* Top-level sentence frames */}
    {topic.sentenceFrames && topic.sentenceFrames.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Sentence Structure</h2>
        <div class="spoke__frames">
          {topic.sentenceFrames.map((frame) => (
            <SentenceFrameComponent frame={frame} />
          ))}
        </div>
      </section>
    )}

    {relatedSits.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Situations that use this</h2>
        <ul class="spoke__related-list">
          {relatedSits.map((s) => s && (
            <li>
              <a href={`${base}/situations/${s.slug}/`} class="spoke__related-link">
                {s.theme}{s.subtheme ? ` · ${s.subtheme}` : ''} →
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* Progression — always last, serves as a summary of the concept across levels */}
    {topic.progression && topic.progression.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Progression</h2>
        <ProgressionTable rows={topic.progression} title="" />
      </section>
    )}

  </div><!-- /.spoke -->
  </div><!-- /.foundation-shell -->
</BaseLayout>

<style>
  .spoke {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .spoke__nav { margin-bottom: 1.5rem; }

  .spoke__back {
    color: var(--ink-faint);
    text-decoration: none;
    transition: color .1s;
  }
  .spoke__back:hover { color: var(--accent-deep); }

  .spoke__header { margin-bottom: 2.5rem; }

  .spoke__category { margin-bottom: .5rem; }

  .spoke__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 .75rem;
    line-height: 1.2;
  }

  .spoke__intro {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  /* ── Sections ── */
  .spoke__section {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-2);
  }

  .spoke__section:first-of-type { border-top: none; padding-top: 0; }

  .spoke__section-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .spoke__section-body {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  .spoke__frames {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .spoke__verbs {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Example table (passive tenses, Konj. forms, modal reference) ── */
  .spoke__ex-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
  }

  .spoke__ex-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
  }

  .spoke__ex-table tr { border-bottom: 1px solid var(--border-2); }
  .spoke__ex-table tr:last-child { border-bottom: none; }
  .spoke__ex-table tr:hover td { background: var(--surface); }

  .spoke__ex-table td { padding: .625rem 1rem; vertical-align: middle; }

  .spoke__ex-label {
    font-family: var(--font-mono);
    font-size: .8rem;
    font-weight: 600;
    color: var(--accent-deep);
    white-space: nowrap;
    width: 22%;
  }

  .spoke__ex-de {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    width: 42%;
  }

  .spoke__ex-en {
    font-family: var(--font-sans);
    font-size: .8125rem;
    color: var(--ink-soft);
    width: 36%;
  }

  /* ── Breadcrumb + sibling strip (child pages) ── */
  .spoke__breadcrumb {
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .spoke__back {
    font-family: var(--font-sans);
    font-size: .8125rem;
    font-weight: 500;
    color: var(--ink-faint);
    text-decoration: none;
    transition: color .1s;
  }
  .spoke__back:hover { color: var(--accent-deep); }

  .spoke__sibling-strip {
    display: flex;
    flex-wrap: wrap;
    gap: .375rem;
  }

  .spoke__sibling-link {
    font-family: var(--font-sans);
    font-size: .8125rem;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    padding: .3rem .75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    transition: background .1s, color .1s, border-color .1s;
  }
  .spoke__sibling-link:hover {
    background: var(--accent-bg);
    color: var(--accent-deep);
    border-color: var(--accent-deep);
  }
  .spoke__sibling-link--active {
    background: var(--accent-bg);
    color: var(--accent-deep);
    border-color: var(--accent-deep);
    font-weight: 600;
  }

  /* ── Tense accordion ── */
  .tense-accordion {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .tense-accordion__item {
    border-bottom: 1px solid var(--border);
  }
  .tense-accordion__item:last-child { border-bottom: none; }

  .tense-accordion__summary {
    display: flex;
    align-items: baseline;
    gap: .75rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    background: var(--surface);
    transition: background .1s;
    user-select: none;
  }
  .tense-accordion__summary::-webkit-details-marker { display: none; }
  .tense-accordion__summary:hover { background: var(--accent-bg); }
  .tense-accordion__item[open] > .tense-accordion__summary {
    background: var(--accent-bg);
    border-bottom: 1px solid var(--border);
  }

  .tense-accordion__title {
    font-family: var(--font-sans);
    font-size: .9375rem;
    font-weight: 700;
    color: var(--ink);
    flex-shrink: 0;
  }

  .tense-accordion__teaser {
    font-family: var(--font-serif);
    font-size: .8125rem;
    color: var(--ink-soft);
    flex: 1;
  }

  .tense-accordion__chevron {
    font-size: 1.125rem;
    color: var(--ink-faint);
    flex-shrink: 0;
    transition: transform .2s;
    display: inline-block;
  }
  .tense-accordion__item[open] .tense-accordion__chevron {
    transform: rotate(90deg);
  }

  .tense-accordion__body {
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--paper);
  }

  .tense-accordion__full-link {
    font-family: var(--font-sans);
    font-size: .8125rem;
    font-weight: 500;
    color: var(--accent-deep);
    text-decoration: none;
    padding-top: .75rem;
    border-top: 1px solid var(--border-2);
    display: block;
  }
  .tense-accordion__full-link:hover { text-decoration: underline; }

  /* ── Sidebar children ── */
  .sidebar__children {
    list-style: none;
    margin: .25rem 0 .25rem .75rem;
    padding: 0;
    border-left: 2px solid var(--border);
  }

  .sidebar__link--child {
    font-size: .8125rem;
    padding: .3rem .5rem;
    color: var(--ink-soft);
  }

  /* ── Placeholder ── */
  .spoke__placeholder { margin-bottom: 2rem; }

  .placeholder-card {
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: var(--r-md);
    padding: 1.5rem;
  }

  .placeholder-card__label { color: var(--ink-mute); margin-bottom: .5rem; }

  .placeholder-card__body {
    font-family: var(--font-serif);
    font-size: .9375rem;
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Related ── */
  .spoke__related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .375rem;
  }

  .spoke__related-link {
    font-family: var(--font-sans);
    font-size: .9375rem;
    color: var(--accent-deep);
    text-decoration: none;
    font-weight: 500;
  }
  .spoke__related-link:hover { text-decoration: underline; }

  /* ── Shell + Sidebar ── */
  .foundation-shell {
    display: flex;
    min-height: 100vh;
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .sidebar {
    width: var(--sidebar-w);
    flex-shrink: 0;
    border-right: 1px solid var(--border);
    padding: 1.5rem 1rem 2rem;
    position: sticky;
    top: 52px;
    height: calc(100vh - 52px);
    overflow-y: auto;
    background: var(--surface);
  }

  .sidebar__home {
    display: block;
    color: var(--ink-faint);
    text-decoration: none;
    margin-bottom: 1.5rem;
    padding: 0 .5rem;
    transition: color .1s;
  }
  .sidebar__home:hover { color: var(--accent-deep); }

  .sidebar__group { margin-bottom: 1.25rem; }

  .sidebar__theme {
    display: block;
    padding: 0 .5rem .375rem;
    color: var(--accent-deep);
    text-decoration: none;
    margin-bottom: .25rem;
    transition: color .1s;
  }
  .sidebar__theme:hover { color: var(--accent); }

  .sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar__link {
    display: block;
    padding: .375rem .5rem;
    border-radius: var(--r-sm);
    font-family: var(--font-sans);
    font-size: .875rem;
    color: var(--ink-body);
    text-decoration: none;
    transition: background .1s, color .1s;
  }
  .sidebar__link:hover { background: var(--accent-bg); color: var(--accent-deep); }
  .sidebar__link--active {
    background: var(--accent-bg);
    color: var(--accent-deep);
    font-weight: 600;
  }

  .spoke {
    flex: 1;
    min-width: 0;
  }

  /* ── Sidebar toggle (mobile only) ── */
  .sidebar-toggle {
    display: none;
    align-items: center;
    gap: .5rem;
    width: 100%;
    padding: .625rem 1rem;
    background: var(--surface);
    border: none;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: .875rem;
    font-weight: 600;
    color: var(--ink-soft);
    cursor: pointer;
    text-align: left;
  }
  .sidebar-toggle:hover { color: var(--ink); }
  .sidebar-toggle[aria-expanded="true"] { color: var(--accent-deep); background: var(--accent-bg); }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .sidebar { width: 210px; padding: 1.25rem .75rem 2rem; }
    .spoke { padding: 1.75rem 1.75rem; }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .foundation-shell { flex-direction: column; }

    .sidebar-toggle { display: flex; }

    .sidebar {
      width: 100%;
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1rem;
      display: none;
    }
    .sidebar--open { display: block; }

    .spoke { padding: 1.25rem 1rem 3rem; }
    .spoke__title { font-size: 1.75rem; }
    .spoke__section { overflow-x: auto; }
  }
</style>

<script is:inline>
  var toggle = document.getElementById('foundation-sidebar-toggle');
  var sidebar = document.getElementById('foundation-sidebar');
  if (toggle && sidebar) {
    toggle.addEventListener('click', function() {
      var open = sidebar.classList.toggle('sidebar--open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  }
</script>
