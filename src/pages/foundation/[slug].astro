---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TenseMap from '../../components/TenseMap.astro';
import TenseLadder from '../../components/TenseLadder.astro';
import ModalStack from '../../components/ModalStack.astro';
import VerbConjugationComponent from '../../components/VerbConjugation.astro';
import SentenceFrameComponent from '../../components/SentenceFrame.astro';
import ConnectorList from '../../components/ConnectorList.astro';
import ProgressionTable from '../../components/ProgressionTable.astro';
import Callout from '../../components/Callout.astro';
import { foundationTopics, getFoundationTopic } from '../../data/foundation';
import { situations } from '../../data/index';

export function getStaticPaths() {
  return foundationTopics.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const topic = getFoundationTopic(slug);
if (!topic) throw new Error(`No foundation topic for slug: ${slug}`);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const hasContent =
  (topic.sections?.length ?? 0) > 0 ||
  (topic.tenseLadder?.length ?? 0) > 0 ||
  (topic.tenseOverviews?.length ?? 0) > 0 ||
  (topic.verbConjugations?.length ?? 0) > 0 ||
  (topic.sentenceFrames?.length ?? 0) > 0 ||
  (topic.progression?.length ?? 0) > 0 ||
  (topic.modalStack?.length ?? 0) > 0;

const relatedSits = (topic.relatedSituations ?? [])
  .map((s) => situations.find((sit) => sit.slug === s))
  .filter(Boolean);
---
<BaseLayout title={`${topic.title} · Foundation · German Reference System`}>
  <div class="spoke">

    <div class="spoke__nav">
      <a href={`${base}/foundation/`} class="spoke__back eyebrow">← Foundation</a>
    </div>

    <header class="spoke__header">
      {topic.category && (
        <div class="eyebrow spoke__category">{topic.category}</div>
      )}
      <h1 class="spoke__title">{topic.title}</h1>
      <p class="spoke__intro">{topic.intro}</p>
    </header>

    {!hasContent && (
      <div class="spoke__placeholder">
        <div class="placeholder-card">
          <div class="eyebrow placeholder-card__label">Content coming soon</div>
          <p class="placeholder-card__body">
            The {topic.title} page will include sentence-structure diagrams,
            a CEFR progression table, and worked examples drawn from real situations.
            Drop in the data and this page renders automatically.
          </p>
        </div>
      </div>
    )}

    {/* Named sections (satzbau-style) */}
    {topic.sections && topic.sections.map((section) => (
      <section class="spoke__section">
        <h2 class="spoke__section-title">{section.title}</h2>

        {section.body && (
          <p class="spoke__section-body">{section.body}</p>
        )}

        {section.connectors && section.connectors.length > 0 && (
          <ConnectorList groups={section.connectors} />
        )}

        {section.exampleTable && section.exampleTable.length > 0 && (
          <div class="spoke__ex-table-wrap">
            <table class="spoke__ex-table">
              <tbody>
                {section.exampleTable.map((row) => (
                  <tr>
                    <td class="spoke__ex-label">{row.label}</td>
                    <td class="spoke__ex-de">{row.de}</td>
                    {row.en && <td class="spoke__ex-en">{row.en}</td>}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {section.sentenceFrames && section.sentenceFrames.length > 0 && (
          <div class="spoke__frames">
            {section.sentenceFrames.map((frame) => (
              <SentenceFrameComponent frame={frame} />
            ))}
          </div>
        )}

        {section.callout && (
          <Callout kind={section.callout.kind ?? 'tip'} label={section.callout.label}>
            {section.callout.text}
          </Callout>
        )}
      </section>
    ))}

    {/* Tense ladder (tense-stack page) */}
    {topic.tenseLadder && topic.tenseLadder.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">The Tense Ladder</h2>
        <TenseLadder rows={topic.tenseLadder} habenSein={topic.habenSein} />
      </section>
    )}

    {/* Tense overview map (tense-stack page) */}
    {topic.tenseOverviews && topic.tenseOverviews.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">The Eight Tenses</h2>
        <TenseMap tenses={topic.tenseOverviews} />
      </section>
    )}

    {/* Modal stacking table */}
    {topic.modalStack && topic.modalStack.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Modal Stacking — All Constructions</h2>
        <ModalStack rows={topic.modalStack} />
      </section>
    )}

    {/* Top-level verb conjugations (verb-tenses page) */}
    {topic.verbConjugations && topic.verbConjugations.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Conjugations</h2>
        <div class="spoke__verbs">
          {topic.verbConjugations.map((v) => (
            <VerbConjugationComponent verb={v} />
          ))}
        </div>
      </section>
    )}

    {/* Top-level sentence frames */}
    {topic.sentenceFrames && topic.sentenceFrames.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Sentence Structure</h2>
        <div class="spoke__frames">
          {topic.sentenceFrames.map((frame) => (
            <SentenceFrameComponent frame={frame} />
          ))}
        </div>
      </section>
    )}

    {topic.progression && topic.progression.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Progression</h2>
        <ProgressionTable rows={topic.progression} title="" />
      </section>
    )}

    {relatedSits.length > 0 && (
      <section class="spoke__section">
        <h2 class="spoke__section-title">Situations that use this</h2>
        <ul class="spoke__related-list">
          {relatedSits.map((s) => s && (
            <li>
              <a href={`${base}/situations/${s.slug}/`} class="spoke__related-link">
                {s.theme}{s.subtheme ? ` · ${s.subtheme}` : ''} →
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .spoke {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .spoke__nav { margin-bottom: 1.5rem; }

  .spoke__back {
    color: var(--ink-faint);
    text-decoration: none;
    transition: color .1s;
  }
  .spoke__back:hover { color: var(--accent-deep); }

  .spoke__header { margin-bottom: 2.5rem; }

  .spoke__category { margin-bottom: .5rem; }

  .spoke__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 .75rem;
    line-height: 1.2;
  }

  .spoke__intro {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  /* ── Sections ── */
  .spoke__section {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-2);
  }

  .spoke__section:first-of-type { border-top: none; padding-top: 0; }

  .spoke__section-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .spoke__section-body {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  .spoke__frames {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .spoke__verbs {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Example table (passive tenses, Konj. forms, modal reference) ── */
  .spoke__ex-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
  }

  .spoke__ex-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
  }

  .spoke__ex-table tr { border-bottom: 1px solid var(--border-2); }
  .spoke__ex-table tr:last-child { border-bottom: none; }
  .spoke__ex-table tr:hover td { background: var(--surface); }

  .spoke__ex-table td { padding: .625rem 1rem; vertical-align: middle; }

  .spoke__ex-label {
    font-family: var(--font-mono);
    font-size: .8rem;
    font-weight: 600;
    color: var(--accent-deep);
    white-space: nowrap;
    width: 22%;
  }

  .spoke__ex-de {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
    width: 42%;
  }

  .spoke__ex-en {
    font-family: var(--font-sans);
    font-size: .8125rem;
    color: var(--ink-soft);
    width: 36%;
  }

  /* ── Placeholder ── */
  .spoke__placeholder { margin-bottom: 2rem; }

  .placeholder-card {
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: var(--r-md);
    padding: 1.5rem;
  }

  .placeholder-card__label { color: var(--ink-mute); margin-bottom: .5rem; }

  .placeholder-card__body {
    font-family: var(--font-serif);
    font-size: .9375rem;
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Related ── */
  .spoke__related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .375rem;
  }

  .spoke__related-link {
    font-family: var(--font-sans);
    font-size: .9375rem;
    color: var(--accent-deep);
    text-decoration: none;
    font-weight: 500;
  }
  .spoke__related-link:hover { text-decoration: underline; }
</style>
