---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { foundationTopics, getFoundationTopic } from '../../data/foundation';
import { situations } from '../../data/index';

export function getStaticPaths() {
  return foundationTopics.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const topic = getFoundationTopic(slug);
if (!topic) throw new Error(`No foundation topic for slug: ${slug}`);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const relatedSits = (topic.relatedSituations ?? [])
  .map((s) => situations.find((sit) => sit.slug === s))
  .filter(Boolean);
---
<BaseLayout title={`${topic.title} · Foundation · German Reference System`}>
  <div class="spoke">

    <div class="spoke__nav">
      <a href={`${base}/foundation/`} class="spoke__back eyebrow">← Foundation</a>
    </div>

    <header class="spoke__header">
      {topic.category && (
        <div class="eyebrow spoke__category">{topic.category}</div>
      )}
      <h1 class="spoke__title">{topic.title}</h1>
      {topic.teaser && (
        <p class="spoke__teaser">{topic.teaser}</p>
      )}
    </header>

    <div class="spoke__placeholder">
      <div class="placeholder-card">
        <div class="eyebrow placeholder-card__label">Content coming soon</div>
        <p class="placeholder-card__body">
          The {topic.title} page will include sentence-structure diagrams,
          a CEFR progression table, and worked examples drawn from real situations.
          Drop in the data and this page renders automatically.
        </p>
      </div>
    </div>

    {relatedSits.length > 0 && (
      <section class="spoke__related">
        <h2 class="spoke__related-heading eyebrow">Situations that use this</h2>
        <ul class="spoke__related-list">
          {relatedSits.map((s) => s && (
            <li>
              <a href={`${base}/situations/${s.slug}/`} class="spoke__related-link">
                {s.theme}{s.subtheme ? ` · ${s.subtheme}` : ''} →
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .spoke {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .spoke__nav { margin-bottom: 1.5rem; }

  .spoke__back {
    color: var(--ink-faint);
    text-decoration: none;
    transition: color .1s;
  }
  .spoke__back:hover { color: var(--accent-deep); }

  .spoke__category { margin-bottom: .5rem; }

  .spoke__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 .5rem;
    line-height: 1.2;
  }

  .spoke__teaser {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .spoke__placeholder { margin-bottom: 2rem; }

  .placeholder-card {
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: var(--r-md);
    padding: 1.5rem;
  }

  .placeholder-card__label { color: var(--ink-mute); margin-bottom: .5rem; }

  .placeholder-card__body {
    font-family: var(--font-serif);
    font-size: .9375rem;
    color: var(--ink-soft);
    line-height: 1.65;
    margin: 0;
  }

  .spoke__related-heading { margin-bottom: .75rem; }

  .spoke__related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .375rem;
  }

  .spoke__related-link {
    font-family: var(--font-sans);
    font-size: .9375rem;
    color: var(--accent-deep);
    text-decoration: none;
    font-weight: 500;
  }
  .spoke__related-link:hover { text-decoration: underline; }
</style>
